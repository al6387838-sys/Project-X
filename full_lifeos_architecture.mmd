graph TD
    subgraph LifeOS
        subgraph Core Engines
            LG(Life Graph)
            ME(Memory Engine)
            CE(Context Engine)
            DE(Decision Engine)
            AE(Action Engine)
            FE(Future Engine)
            MIE(Mission Engine)
            C(Companion)
            EE(Evolution Engine)
            TE(Trust Engine)

            LG <--> KEM;
            ME <--> KEM;
            CE <--> KEM;
            DE <--> KEM;
            AE <--> KEM;
            FE <--> KEM;
            MIE <--> KEM;
            C <--> KEM;
            EE <--> KEM;
            TE <--> KEM;

            LG <--> KSM;
            ME <--> KSM;
            CE <--> KSM;
            DE <--> KSM;
            AE <--> KSM;
            FE <--> KSM;
            MIE <--> KSM;
            C <--> KSM;
            EE <--> KSM;
            TE <--> KSM;
        end

        subgraph Life Kernel
            KR[Kernel Runtime]
            KEM[Kernel Event Manager]
            KSM[Kernel State Manager]
            KS[Kernel Scheduler]
            KM[Kernel Monitor]

            subgraph Event Queues
                EQ[Event Queue]
                PQ[Priority Queue]
                ExQ[Execution Queue]
            end

            KR --> KEM;
            KR --> KSM;
            KR --> KS;
            KR --> KM;

            KEM --> EQ;
            KS --> EQ;
            EQ --> PQ;
            EQ --> ExQ;
        end

        style KEM fill:#f9f,stroke:#333,stroke-width:2px;
        style KSM fill:#ccf,stroke:#333,stroke-width:2px;
        style KR fill:#cfc,stroke:#333,stroke-width:2px;
    end

    UI[User Interface] -- Interage --> KR;
    SDK[LifeOS SDK] -- Publica Eventos --> KEM;
    Plugins[External Plugins] -- Interage via SDK --> SDK;
    SDK -- Consulta Estado --> KSM;

    style UI fill:#ffc,stroke:#333,stroke-width:2px;
    style SDK fill:#fcf,stroke:#333,stroke-width:2px;
    style Plugins fill:#cff,stroke:#333,stroke-width:2px;
