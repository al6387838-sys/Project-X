# LifeOS Enterprise v46.0.0 — Environment Configuration
# Copie para .env e preencha os valores reais.
# NUNCA comite .env no version control.
# NUNCA compartilhe .env com credenciais reais.

# ═══ Core ═══════════════════════════════════════════════════════════════════
LIFEOS_ENV=production
LIFEOS_VERSION=v46.0.0
LOG_LEVEL=INFO
LIFEOS_ENV_PORT=3000

# ═══ Security ═══════════════════════════════════════════════════════════════
# Gerar com: python3 -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=your_32_byte_hex_key_here

# ═══ Cloudflare ═════════════════════════════════════════════════════════════
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_PROJECT_NAME=lifeos-enterprise
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# ═══ KV / R2 ════════════════════════════════════════════════════════════════
LIFEOS_KV_NAMESPACE_ID=your_kv_namespace_id
R2_BUCKET_LIFEOS_FILES=lifeos-files
R2_BUCKET_LIFEOS_DOCUMENTS=lifeos-documents
R2_BUCKET_LIFEOS_STORAGE=lifeos-storage

# ═══ Admin ══════════════════════════════════════════════════════════════════
LIFEOS_ADMIN_EMAIL=al6387838@gmail.com
# Gerar hash com: python3 -c "import hashlib; print(hashlib.sha256('sua_senha'.encode()).hexdigest())"
LIFEOS_ADMIN_PASSWORD_HASH=your_sha256_hash_here

# ═══ Session ════════════════════════════════════════════════════════════════
LIFEOS_SESSION_SECRET=your_random_256bit_secret

# ═══ Stripe (Billing) ═══════════════════════════════════════════════════════
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...
STRIPE_PRICE_ENTERPRISE=price_...
STRIPE_PRICE_LIFETIME=price_...

# ═══ Google OAuth 2.0 ══════════════════════════════════════════════════════
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://lifeos-enterprise.pages.dev/api/auth/google/callback

# ═══ Apple Sign In ═════════════════════════════════════════════════════════
APPLE_CLIENT_ID=your_apple_client_id
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
APPLE_PRIVATE_KEY_PATH=./certs/AuthKey_*.p8

# ═══ WhatsApp Business API ═════════════════════════════════════════════════
WHATSAPP_API_KEY=your_whatsapp_api_key
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token

# ═══ SMTP / Email Delivery ═════════════════════════════════════════════════
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_sendgrid_api_key
SMTP_FROM=noreply@lifeos.app
SMTP_FROM_NAME=LifeOS Enterprise
SMTP_ENCRYPTION=tls

# ═══ OpenAI (AI Orchestration) ════════════════════════════════════════════
OPENAI_API_KEY=your_openai_api_key
OPENAI_ORG_ID=your_openai_org_id
OPENAI_MODEL=gpt-4o-mini

# ═══ Cloudflare Turnstile (CAPTCHA) ═══════════════════════════════════════
CLOUDFLARE_TURNSTILE_SITE_KEY=your_turnstile_site_key
CLOUDFLARE_TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# ═══ Analytics ═════════════════════════════════════════════════════════════
GA_MEASUREMENT_ID=G-XXXXXXXXXX
PLAUSIBLE_DOMAIN=lifeos.app

# ═══ Observability ═════════════════════════════════════════════════════════
GRAFANA_PASSWORD=change_me_in_production
LOKI_ENDPOINT=http://localhost:3100
PROMETHEUS_ENDPOINT=http://localhost:9090

# ═══ Backup ════════════════════════════════════════════════════════════════
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30
