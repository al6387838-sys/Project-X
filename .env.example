# LifeOS V1.0 RC — Environment Configuration
# Copy to .env and fill in your values
# NEVER commit .env to version control

# ─── Core ───────────────────────────────────────────────────────────────────
LIFEOS_ENV=production
LIFEOS_VERSION=1.0.0-rc
LOG_LEVEL=INFO

# ─── Security ───────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=your_32_byte_hex_key_here

# ─── Cloud Sync ─────────────────────────────────────────────────────────────
CLOUD_SYNC_ENDPOINT=https://sync.lifeos.app/v1
CLOUD_SYNC_API_KEY=your_api_key_here

# ─── Observability ──────────────────────────────────────────────────────────
GRAFANA_PASSWORD=change_me_in_production

# ─── Backup ─────────────────────────────────────────────────────────────────
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30
