/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=(), accelerometer=(), autoplay=(), clipboard-write=(self), display-capture=(), encrypted-media=(), fullscreen=(self), gyroscope=(), magnetometer=(), picture-in-picture=(), publickey-credentials-get=(self), screen-wake-lock=(), sync-xhr=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-DNS-Prefetch-Control: on
  X-Permitted-Cross-Domain-Policies: none

/*.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/app
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/admin
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/dashboard
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/*.json
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/*.css
  Cache-Control: public, max-age=0, must-revalidate
  Vary: Accept-Encoding

/*.js
  Cache-Control: public, max-age=0, must-revalidate
  Vary: Accept-Encoding

/version-display.js
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/release.json
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/build-meta.json
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/health.json
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/sw.js
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/*.woff
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  Cache-Control: public, max-age=604800, immutable

/*.webp
  Cache-Control: public, max-age=604800, immutable

/*.png
  Cache-Control: public, max-age=604800, immutable

/*.ico
  Cache-Control: public, max-age=86400

/api/*
  Cache-Control: private, no-store, no-cache
  X-Robots-Tag: noindex
  X-Content-Type-Options: nosniff

/admin/*
  X-Robots-Tag: noindex, nofollow
  X-Frame-Options: DENY
  Cache-Control: private, no-store

/app/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: public, max-age=0, must-revalidate

/login/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: private, no-store

/register/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: private, no-store

/privacy/*
  Cache-Control: public, max-age=86400

/terms/*
  Cache-Control: public, max-age=86400

/contact/*
  Cache-Control: public, max-age=0, must-revalidate

/status/*
  Cache-Control: public, max-age=60

/api/health
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/.well-known/security.txt
  Cache-Control: public, max-age=86400
